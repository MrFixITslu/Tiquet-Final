# Facebook App ID: Client ID used to enable production Facebook Login OAuth flows.
# Set up a Web platform in the Meta for Developers console with this app's URL as the site URL.
VITE_FACEBOOK_APP_ID=

# Production server settings
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Disable public self-signup in production unless you intentionally want open registration.
ALLOW_PUBLIC_REGISTRATION=false

# Host-side bind for Docker Compose when Nginx Proxy Manager proxies via the host.
# Leave HOST_BIND_IP at 127.0.0.1 so the app is not directly public.
HOST_BIND_IP=127.0.0.1
HOST_PORT=18080
